{
  "name": "weebster-backend",
  "version": "1.0.0",
  "description": "Weebster E-commerce API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "health": "curl http://localhost:8000/api/v1/health",
    "seed": "node scripts/seed.js",
    "backup": "node scripts/backup.js",
    "reset": "node scripts/reset.js",
    "generate": "node scripts/generate.js",
    "cleanup": "node scripts/cleanup.js"
  },
  "keywords": [
    "ecommerce",
    "api",
    "express"
  ],
  "author": "Weebster Architecture Team",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.12.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.1",
    "nodemailer": "^6.9.9",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  },
  "jest": {
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"]
  }
}
